# IBM Bob API Configuration
# Replace these values with your actual IBM Bob API credentials

# The Bob API endpoint URL
# Common formats:
# - https://us-south.ml.cloud.ibm.com/ml/v1/text/chat?version=2023-05-29
# - https://eu-gb.ml.cloud.ibm.com/ml/v1/text/chat?version=2023-05-29
# - https://jp-tok.ml.cloud.ibm.com/ml/v1/text/chat?version=2023-05-29
# 
# To find your endpoint:
# 1. Go to IBM Cloud Console (https://cloud.ibm.com)
# 2. Navigate to your watsonx.ai instance
# 3. Go to "Credentials" or "Service credentials"
# 4. Copy the API endpoint URL
BOB_API_ENDPOINT=https://us-south.ml.cloud.ibm.com/ml/v1/text/chat?version=2023-05-29

# Your IBM Bob API Key
# To find your API key:
# 1. Go to IBM Cloud Console
# 2. Navigate to "Manage" > "Access (IAM)" > "API keys"
# 3. Create a new API key or use an existing one
BOB_API_KEY=your_api_key_here