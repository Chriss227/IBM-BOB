# Google Gemini API Configuration
# Get your API key from: https://aistudio.google.com/app/apikey
# New API keys start with "AQ." (e.g., AQ.Ab8RN6IxkvazkDr16g5K...)
# Old API keys started with "AIza" (both formats are supported)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_KEY_FALLBACK=your_fallback_gemini_api_key_here

# Server Configuration
PORT=8000
HOST=0.0.0.0

# Environment
ENVIRONMENT=development

# Production frontend URL for CORS, for example:
# FRONTEND_URL=https://your-app.vercel.app
